---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Hare Line | T2H3">
  <section class="mx-auto max-w-6xl px-6 py-10">
    <div class="border-b border-red-700/30 pb-8">
      <p class="text-sm font-black uppercase tracking-[0.3em] text-teal-300">
        True Trail
      </p>
      <h1 class="mt-3 text-4xl font-black text-white sm:text-5xl">Hare Line</h1>
      <p class="mt-3 text-zinc-300">Upcoming True Trail hashes.</p>
    </div>

    <div id="hareline-events" class="mt-8 grid gap-5">
      <div class="rounded-2xl border border-red-600/20 bg-zinc-900 p-6">
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">
          Loading Hare Line...
        </p>
      </div>
    </div>
  </section>

  <script type="module">

    import Papa from "https://cdn.jsdelivr.net/npm/papaparse@5.4.1/+esm";

    const SHEET_URL =
      "https://docs.google.com/spreadsheets/d/e/2PACX-1vRiPjzlw_BJmHOllbHmOLWwtTfMnQ5QdECoNPFunNxrl2x6U0RQWl7cv6CYDdmyk_8fqRSb56kKJmqf/pub?gid=0&single=true&output=csv";

    const clean = (value) => String(value || "").trim();

    const escapeHtml = (value) =>
      clean(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const parseTime = (time) => {
      if (!time) return null;
      const parsedTime = new Date(`January 1, 2000 ${clean(time)}`);
      return isNaN(parsedTime.getTime()) ? null : parsedTime;
    };

    const formatDate = (date) => {
      if (!date) return "";
      const parsedDate = new Date(`${clean(date)}T12:00:00`);
      if (isNaN(parsedDate.getTime())) return clean(date);
      return parsedDate.toLocaleDateString("en-CA", {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric",
      });
    };

    const formatTimeFromDate = (date) =>
      date.toLocaleTimeString("en-CA", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });

    const formatTime = (time) => {
      const parsedTime = parseTime(time);
      return parsedTime ? formatTimeFromDate(parsedTime) : clean(time);
    };

    const addMinutes = (time, minutesToAdd) => {
      const parsedTime = parseTime(time);
      if (!parsedTime) return clean(time);
      parsedTime.setMinutes(parsedTime.getMinutes() + minutesToAdd);
      return formatTimeFromDate(parsedTime);
    };

    async function getEvents() {
      const response = await fetch(SHEET_URL);
      const csv = await response.text();
      const parsed = Papa.parse(csv, {
        header: true,
        skipEmptyLines: true,
      });

      return parsed.data
        .filter((event) => clean(event.published).toUpperCase() === "TRUE")
        .sort((a, b) => clean(a.date).localeCompare(clean(b.date)));
    }

    async function renderEventCard(event) {
      const hasDirections = clean(event.mapUrl) !== "";
      const hasPaypal = clean(event.paypalUrl) !== "";
      const hasFacebook = clean(event.facebookUrl) !== "";

      return `
        <article class="rounded-2xl border border-red-600/20 bg-zinc-900 p-5 shadow-xl shadow-black/20">
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">Trail #${escapeHtml(event.trailNumber)}</p>
          <h2 class="mt-2 text-2xl font-black text-white">${escapeHtml(event.title)}</h2>
          <p class="mt-2 text-zinc-300">${escapeHtml(event.description)}</p>

          <dl class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
            <div><dt class="text-zinc-500">Date</dt><dd class="font-bold text-white">${formatDate(event.date)}</dd></div>
            <div><dt class="text-zinc-500">Pack Gathers</dt><dd class="font-bold text-white">${formatTime(event.time)}</dd></div>
            <div><dt class="text-zinc-500">Hares Away</dt><dd class="font-bold text-white">${addMinutes(event.time, 15)}</dd></div>
            <div><dt class="text-zinc-500">On Out</dt><dd class="font-bold text-white">${addMinutes(event.time, 30)}</dd></div>
            <div><dt class="text-zinc-500">Location</dt><dd class="font-bold text-white">${escapeHtml(event.locationName) || "TBA"}</dd><dd class="text-zinc-400">${escapeHtml(event.address)}</dd></div>
            <div><dt class="text-zinc-500">Hares</dt><dd class="font-bold text-white">${escapeHtml(event.hares) || "TBA"}</dd></div>
            <div><dt class="text-zinc-500">Theme</dt><dd class="font-bold text-white">${escapeHtml(event.theme) || "TBA"}</dd></div>
            <div><dt class="text-zinc-500">Hash Cash</dt><dd class="font-bold text-white">$${escapeHtml(event.hashCash)}</dd></div>
          </dl>

          ${
            hasDirections || hasPaypal || hasFacebook
              ? `
                <div class="mt-6 flex flex-wrap gap-3">
                  ${
                    hasFacebook
                      ? `<a href="${escapeHtml(event.facebookUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-red-600 px-4 py-2 font-bold text-white hover:bg-red-500">Facebook Event</a>`
                      : ""
                  }
                  ${
                    hasDirections
                      ? `<a href="${escapeHtml(event.mapUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-teal-400 px-4 py-2 font-bold text-teal-300 hover:bg-teal-300 hover:text-black">Get Directions</a>`
                      : ""
                  }
                  ${
                    hasPaypal
                      ? `<a href="${escapeHtml(event.paypalUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-zinc-700 px-4 py-2 font-bold text-zinc-100 hover:bg-zinc-800">Pay Hash Cash</a>`
                      : ""
                  }
                </div>
              `
              : ""
          }
        </article>
      `;
    }

    async function renderEvents(events) {
      const container = document.querySelector("#hareline-events");

      if (!events.length) {
        container.innerHTML = `
          <div class="rounded-2xl border border-red-600/20 bg-zinc-900 p-6">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">No trails posted</p>
            <h2 class="mt-3 text-2xl font-black text-white">No published hashes yet.</h2>
            <p class="mt-3 text-zinc-300">Check back soon.</p>
          </div>
        `;
        return;
      }

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const getEventDate = (event) => {
        const eventDate = new Date(`${clean(event.date)}T00:00:00`);
        return isNaN(eventDate.getTime()) ? null : eventDate;
      };

      const upcomingEvents = events
        .filter((event) => {
          const eventDate = getEventDate(event);
          return eventDate && eventDate >= today;
        })
        .slice(0, 4);

      const pastEvents = events
        .filter((event) => {
          const eventDate = getEventDate(event);
          return eventDate && eventDate < today;
        })
        .reverse();

      const upcomingCards = await Promise.all(
        upcomingEvents.map((event) => renderEventCard(event))
      );

      const pastCards = await Promise.all(
        pastEvents.map((event) => renderEventCard(event))
      );

      const upcomingSection =
        upcomingEvents.length > 0
          ? `
            <section class="grid gap-5">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">
                  Upcoming Trails
                </p>
                <h2 class="mt-2 text-2xl font-black text-white">Next 4 Hashes</h2>
              </div>
              ${upcomingCards.join("")}
            </section>
          `
          : `
            <section class="rounded-2xl border border-red-600/20 bg-zinc-900 p-6">
              <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">
                Upcoming Trails
              </p>
              <h2 class="mt-3 text-2xl font-black text-white">No upcoming hashes posted.</h2>
              <p class="mt-3 text-zinc-300">Check back soon.</p>
            </section>
          `;

      const pastSection =
        pastEvents.length > 0
          ? `
            <section class="mt-10 grid gap-5 border-t border-red-700/30 pt-8">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">
                  Past Trails
                </p>
                <h2 class="mt-2 text-2xl font-black text-white">Recent History</h2>
              </div>
              ${pastCards.join("")}
            </section>
          `
          : "";

      container.innerHTML = `
        ${upcomingSection}
        ${pastSection}
      `;
    }

    getEvents()
      .then(renderEvents)
      .catch(() => {
        document.querySelector("#hareline-events").innerHTML = `
          <div class="rounded-2xl border border-red-600/20 bg-zinc-900 p-6">
            <h2 class="text-2xl font-black text-white">Could not load Hare Line</h2>
            <p class="mt-3 text-zinc-300">Try refreshing the page.</p>
          </div>
        `;
      });
  </script>
</BaseLayout>
