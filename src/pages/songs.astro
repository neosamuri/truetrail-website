    const songbook = document.querySelector("#songbook");
    const searchInput = document.querySelector("#song-search");
    const songCount = document.querySelector("#song-count");
    const openAllButton = document.querySelector("#open-all");
    const closeAllButton = document.querySelector("#close-all");

    const escapeHtml = (value) =>
      String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const render = (query = "") => {
      const normalizedQuery = query.trim().toLowerCase();
      let visibleCount = 0;

      const html = songSections
        .map((section) => {
          const songs = section.songs.filter((song) => {
            const haystack = `${song.title} ${song.lyrics}`.toLowerCase();
            return !normalizedQuery || haystack.includes(normalizedQuery);
          });

          if (songs.length === 0) return "";

          visibleCount += songs.length;

          return `
            <section class="rounded-3xl border border-orange-400/20 bg-stone-900 p-5">
              <div class="flex flex-col gap-2 border-b border-stone-800 pb-4">
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-orange-300">
                  ${escapeHtml(section.title)}
                </p>
                <p class="text-sm text-stone-400">${escapeHtml(section.description)}</p>
                <p class="text-xs text-stone-500">${songs.length} song${songs.length === 1 ? "" : "s"}</p>
              </div>

              <div class="mt-5 grid gap-4">
                ${songs
                  .map(
                    (song) => `
                      <details class="song rounded-2xl bg-stone-950 p-4">
                        <summary class="cursor-pointer text-lg font-black text-stone-100 marker:text-orange-300">
                          ${escapeHtml(song.title)}
                        </summary>

                        <pre class="mt-4 whitespace-pre-wrap font-sans text-sm leading-relaxed text-stone-300">${escapeHtml(song.lyrics)}</pre>
                      </details>
                    `
                  )
                  .join("")}
              </div>
            </section>
          `;
        })
        .join("");

      songbook.innerHTML =
        html ||
        `
          <div class="rounded-2xl border border-orange-400/20 bg-stone-900 p-6">
            <p class="font-black text-orange-300">No songs found</p>
            <p class="mt-2 text-stone-300">Try another search.</p>
          </div>
        `;

      songCount.textContent = `${visibleCount} song${visibleCount === 1 ? "" : "s"} shown`;
    };

    searchInput?.addEventListener("input", (event) => {
      render(event.target.value);
    });

    openAllButton?.addEventListener("click", () => {
      document.querySelectorAll("#songbook details").forEach((detail) => {
        detail.open = true;
      });
    });

    closeAllButton?.addEventListener("click", () => {
      document.querySelectorAll("#songbook details").forEach((detail) => {
        detail.open = false;
      });
    });

    render();
  </script>
