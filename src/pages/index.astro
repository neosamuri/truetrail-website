---
import BaseLayout from "../layouts/BaseLayout.astro";

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<BaseLayout title="T2H3 | True Trail Hash House Harriers">
  <section class="mx-auto flex max-w-7xl flex-col gap-10 px-6 py-10">
    <section class="overflow-hidden rounded-[2rem] border border-red-700/40 bg-black shadow-2xl shadow-red-950/20">
      <div class="bg-[url('/images/dark-banner.jpg')] bg-cover bg-center">
        <div class="grid gap-8 bg-black/70 p-6 md:grid-cols-[1.1fr_0.9fr] md:p-10">
          <div class="flex flex-col justify-center gap-5">
            <p class="text-sm font-black uppercase tracking-[0.4em] text-teal-300">
              True Trail Hash House Harriers
            </p>

            <h1 class="max-w-3xl text-5xl font-black uppercase leading-none tracking-tight text-white sm:text-7xl">
              True Trail
            </h1>

            <p class="max-w-2xl border-l-4 border-red-600 pl-4 text-xl font-bold text-zinc-200">
              A drinking club with a running problem. Trails, beer, songs,
              shiggy, and questionable decisions.
            </p>

            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href="/hareline"
                class="rounded-xl bg-red-600 px-5 py-3 font-black text-white hover:bg-red-500"
              >
                View Hare Line
              </a>

              <a
                href="/markings"
                class="rounded-xl border border-teal-400 px-5 py-3 font-bold text-teal-300 hover:bg-teal-300 hover:text-black"
              >
                Trail Markings
              </a>
            </div>
          </div>

          <div class="flex items-center justify-center">
            <img
              src="/images/logosmall.jpg"
              alt="True Trail Hash House Harriers logo"
              class="w-full max-w-[360px] rounded-2xl border-4 border-teal-400 bg-white p-3 shadow-2xl shadow-teal-950/40"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="next-hash">
      <div class="rounded-3xl border border-red-600/30 bg-zinc-900 p-6">
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">
          Loading next hash...
        </p>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-5">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-teal-300">
          New?
        </p>
        <h3 class="mt-2 text-xl font-black text-white">What is hashing?</h3>
        <p class="mt-2 text-zinc-400">
          Part trail run, part scavenger hunt, part social club. Follow flour,
          find beer, sing badly.
        </p>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-5">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-teal-300">
          Pack
        </p>
        <h3 class="mt-2 text-xl font-black text-white">All paces welcome</h3>
        <p class="mt-2 text-zinc-400">
          Runners, walkers, stumblers, and professional shortcutters are all
          welcome.
        </p>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-5">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-teal-300">
          Social
        </p>
        <h3 class="mt-2 text-xl font-black text-white">RSVP on Facebook</h3>
        <p class="mt-2 text-zinc-400">
          Use the Facebook event to mark yourself as going and keep up with
          last-minute updates.
        </p>
      </div>
    </section>
  </section>

  <script define:vars={{ googleMapsApiKey }} type="module">

    import Papa from "https://cdn.jsdelivr.net/npm/papaparse@5.4.1/+esm";

    const SHEET_URL =
      "https://docs.google.com/spreadsheets/d/e/2PACX-1vRiPjzlw_BJmHOllbHmOLWwtTfMnQ5QdECoNPFunNxrl2x6U0RQWl7cv6CYDdmyk_8fqRSb56kKJmqf/pub?gid=0&single=true&output=csv";

    const clean = (value) => String(value || "").trim();

    const escapeHtml = (value) =>
      clean(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const parseTime = (time) => {
      if (!time) return null;
      const parsedTime = new Date(`January 1, 2000 ${clean(time)}`);
      return isNaN(parsedTime.getTime()) ? null : parsedTime;
    };

    const formatDate = (date) => {
      if (!date) return "";
      const parsedDate = new Date(`${clean(date)}T12:00:00`);
      if (isNaN(parsedDate.getTime())) return clean(date);
      return parsedDate.toLocaleDateString("en-CA", {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric",
      });
    };

    const formatTimeFromDate = (date) =>
      date.toLocaleTimeString("en-CA", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });

    const formatTime = (time) => {
      const parsedTime = parseTime(time);
      return parsedTime ? formatTimeFromDate(parsedTime) : clean(time);
    };

    const addMinutes = (time, minutesToAdd) => {
      const parsedTime = parseTime(time);
      if (!parsedTime) return clean(time);
      parsedTime.setMinutes(parsedTime.getMinutes() + minutesToAdd);
      return formatTimeFromDate(parsedTime);
    };

    async function getEvents() {
      const response = await fetch(SHEET_URL);
      const csv = await response.text();
      const parsed = Papa.parse(csv, {
        header: true,
        skipEmptyLines: true,
      });

      return parsed.data
        .filter((event) => clean(event.published).toUpperCase() === "TRUE")
        .sort((a, b) => clean(a.date).localeCompare(clean(b.date)));
    }

    const getEventDateTime = (event, minutesToAdd = 0) => {
      const date = clean(event.date);
      const time = clean(event.time);
      if (!date || !time) return null;

      const parsedTime = parseTime(time);
      if (!parsedTime) return null;

      const eventDate = new Date(`${date}T00:00:00`);
      eventDate.setHours(parsedTime.getHours(), parsedTime.getMinutes() + minutesToAdd, 0, 0);
      return isNaN(eventDate.getTime()) ? null : eventDate;
    };

    const getCountdown = (event) => {
      const eventDate = getEventDateTime(event, 15);
      if (!eventDate) return "Date TBA";

      const diff = eventDate - new Date();
      if (diff <= 0) return "Trail is today or already started";

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);

      return `${days} days, ${hours} hours, ${minutes} minutes`;
    };

    const getNextEvent = (events) => {
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      return events.find((event) => {
        const eventDate = new Date(`${clean(event.date)}T00:00:00`);
        return !isNaN(eventDate.getTime()) && eventDate >= today;
      });
    };

    async function renderNextHash(event) {
      const container = document.querySelector("#next-hash");

      if (!event) {
        container.innerHTML = `
          <section class="rounded-3xl border border-red-600/30 bg-zinc-900 p-6">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">Next Hash</p>
            <h2 class="mt-3 text-3xl font-black text-white">No published trails yet</h2>
            <p class="mt-3 text-zinc-300">Check back soon.</p>
          </section>
        `;
        return;
      }

      const hasMap = clean(event.address) !== "" || clean(event.locationName) !== "" || clean(event.mapUrl) !== "";
      const hasGoogleMapEmbed = Boolean(googleMapsApiKey) && (clean(event.address) !== "" || clean(event.locationName) !== "");
      const hasDirections = clean(event.mapUrl) !== "";
      const hasPaypal = clean(event.paypalUrl) !== "";
      const hasFacebook = clean(event.facebookUrl) !== "";

      const addressQuery = encodeURIComponent(`${clean(event.locationName)} ${clean(event.address)}`);
      const mapEmbedUrl = hasGoogleMapEmbed
        ? `https://www.google.com/maps/embed/v1/place?key=${googleMapsApiKey}&q=${addressQuery}`
        : "";

      const buttonsHtml =
        hasDirections || hasPaypal || hasFacebook
          ? `
            <div class="mt-6 flex flex-wrap gap-3">
              ${
                hasFacebook
                  ? `<a href="${escapeHtml(event.facebookUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-red-600 px-5 py-3 font-black text-white hover:bg-red-500">Facebook Event</a>`
                  : ""
              }
              ${
                hasDirections
                  ? `<a href="${escapeHtml(event.mapUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-teal-400 px-5 py-3 font-bold text-teal-300 hover:bg-teal-300 hover:text-black">Get Directions</a>`
                  : ""
              }
              ${
                hasPaypal
                  ? `<a href="${escapeHtml(event.paypalUrl)}" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-zinc-700 px-5 py-3 font-bold text-zinc-100 hover:bg-zinc-800">Pay Hash Cash</a>`
                  : ""
              }
            </div>
          `
          : "";

      const mapHtml = hasMap
        ? hasGoogleMapEmbed
          ? `
            <div class="overflow-hidden rounded-2xl border border-zinc-800 bg-black lg:min-h-[490px]">
              <iframe title="Next hash map" src="${mapEmbedUrl}" class="h-[360px] w-full lg:h-full lg:min-h-[490px]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            </div>
          `
          : `
            <div class="flex items-center justify-center rounded-2xl border border-zinc-800 bg-black p-8 lg:min-h-[490px]">
              <div class="text-center">
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">Map unavailable</p>
                <p class="mt-3 text-zinc-400">Add a Google Maps API key or use the directions button.</p>
              </div>
            </div>
          `
        : `
          <div class="flex items-center justify-center rounded-2xl border border-zinc-800 bg-black p-8 lg:min-h-[490px]">
            <div class="text-center">
              <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">Location TBA</p>
              <p class="mt-3 text-zinc-400">The hare has not published a location yet.</p>
            </div>
          </div>
        `;

      container.innerHTML = `
        <section class="rounded-3xl border border-red-600/30 bg-zinc-900 p-6 shadow-2xl shadow-red-950/20">
          <p class="mb-3 text-sm font-bold uppercase tracking-[0.25em] text-red-500">Next Hash</p>

          <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
            <div>
              <h2 class="text-3xl font-black text-white sm:text-5xl">Trail #${escapeHtml(event.trailNumber)}: ${escapeHtml(event.title)}</h2>
              <p class="mt-4 text-xl text-zinc-300">${escapeHtml(event.description)}</p>

              <div class="mt-6 rounded-2xl border border-red-600/20 bg-black p-5">
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-red-500">Starts In</p>
                <p id="countdown" class="mt-2 text-3xl font-black text-white">${getCountdown(event)}</p>
              </div>

              <dl class="mt-6 grid gap-4 text-sm sm:grid-cols-2">
                <div><dt class="text-zinc-500">Date</dt><dd class="font-bold text-white">${formatDate(event.date)}</dd></div>
                <div><dt class="text-zinc-500">Pack Gathers</dt><dd class="font-bold text-white">${formatTime(event.time)}</dd></div>
                <div><dt class="text-zinc-500">Hares Away</dt><dd class="font-bold text-white">${addMinutes(event.time, 15)}</dd></div>
                <div><dt class="text-zinc-500">On Out</dt><dd class="font-bold text-white">${addMinutes(event.time, 30)}</dd></div>
                <div><dt class="text-zinc-500">Location</dt><dd class="font-bold text-white">${escapeHtml(event.locationName) || "TBA"}</dd><dd class="text-zinc-400">${escapeHtml(event.address)}</dd></div>
                <div><dt class="text-zinc-500">Hares</dt><dd class="font-bold text-white">${escapeHtml(event.hares) || "TBA"}</dd></div>
                <div><dt class="text-zinc-500">Hash Cash</dt><dd class="font-bold text-white">$${escapeHtml(event.hashCash)}</dd></div>
              </dl>

              ${buttonsHtml}
            </div>

            ${mapHtml}
          </div>
        </section>
      `;

      setInterval(() => {
        const countdown = document.querySelector("#countdown");
        if (countdown) countdown.textContent = getCountdown(event);
      }, 60000);
    }

    getEvents()
      .then((events) => renderNextHash(getNextEvent(events)))
      .catch(() => {
        document.querySelector("#next-hash").innerHTML = `
          <section class="rounded-3xl border border-red-600/30 bg-zinc-900 p-6">
            <h2 class="text-2xl font-black text-white">Could not load Hare Line</h2>
            <p class="mt-3 text-zinc-300">Try refreshing the page.</p>
          </section>
        `;
      });
  </script>
</BaseLayout>
