---
import "../styles/global.css";

const { title = "T2H3 | True Trail Hash House Harriers" } = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Hare Line", href: "/hareline" },
  { label: "Trail Markings", href: "/markings" },
  { label: "Songs", href: "/songs" },
  { label: "History", href: "/history" },
  { label: "About", href: "/about" },
  { label: "Awards", href: "/awards" },
  { label: "Links", href: "/links" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <meta
      name="description"
      content="True Trail Hash House Harriers. A drinking club with a running problem."
    />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="True Trail Hash House Harriers: trails, beer, songs, and questionable decisions."
    />
    <meta property="og:image" content="/images/logosmall.jpg" />
    <meta property="og:type" content="website" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <header class="sticky top-0 z-50 border-b-4 border-red-700 bg-black/95 text-white shadow-xl shadow-black/40 backdrop-blur">
      <div class="mx-auto max-w-7xl px-5 py-4">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-3">
            <img
              src="/images/logoblack.jpg"
              alt="T2H3 logo"
              class="h-14 w-14 rounded-full border-2 border-teal-400 bg-white object-contain"
            />

            <span class="flex flex-col leading-tight">
              <span class="text-2xl font-black tracking-tight text-red-500">
                T2H3
              </span>
              <span class="text-xs uppercase tracking-[0.25em] text-teal-300">
                True Trail H3
              </span>
            </span>
          </a>
        </div>

        <nav class="mt-4 flex flex-wrap gap-2 text-sm font-bold">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="rounded-full border border-white/20 px-3 py-2 text-white transition hover:border-teal-300 hover:bg-teal-300 hover:text-black"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-12 overflow-hidden border-t-4 border-red-700 bg-black text-sm text-white">
      <div class="bg-[url('/images/footer.jpg')] bg-cover bg-center">
        <div class="bg-black/80 px-5 py-10">
          <div class="mx-auto flex max-w-7xl flex-col gap-3">
            <img
              src="/images/logosmall.jpg"
              alt="True Trail Hash House Harriers"
              class="max-w-xs rounded-xl border border-zinc-800 bg-white p-2"
            />
            <p class="font-black text-red-500">True Trail Hash House Harriers</p>
            <p class="max-w-2xl text-zinc-300">
              T2H3 is an adult social hashing group. Participate at your own risk.
              On-On!
            </p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
